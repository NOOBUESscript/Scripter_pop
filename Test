    end)
end

local function CreateSlider(parent, x, y, width, label, key, default, minV, maxV, scale)
    scale = scale or 1
    minV = minV or 0
    maxV = maxV or 100
    
    Make("TextLabel", {
        Size = UDim2.new(0, width * 0.5, 0, 16 * scale),
        Position = UDim2.new(0, x, 0, y),
        BackgroundTransparency = 1,
        Text = label, TextColor3 = Config.TextDim,
        TextSize = 12 * scale,
        Font = Enum.Font.SourceSans,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = parent
    })
    
    local valTxt = Make("TextLabel", {
        Size = UDim2.new(0, 50 * scale, 0, 16 * scale),
        Position = UDim2.new(0, x + width - 50 * scale, 0, y),
        BackgroundTransparency = 1,
        Text = tostring(default), TextColor3 = Config.TextDim,
        TextSize = 12 * scale,
        Font = Enum.Font.SourceSans,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = parent
    })
    
    local track = Make("Frame", {
        Size = UDim2.new(0, width, 0, 4 * scale),
        Position = UDim2.new(0, x, 0, y + 22 * scale),
        BackgroundColor3 = Config.AccentDim,
        BorderSizePixel = 0, Parent = parent
    })
    AddCorner(track, 2)
    
    local pct = (default - minV) / (maxV - minV)
    local fill = Make("Frame", {
        Size = UDim2.new(pct, 0, 1, 0),
        BackgroundColor3 = Config.Accent,
        BorderSizePixel = 0, Parent = track
    })
    AddCorner(fill, 2)
    
    local knob = Make("TextButton", {
        Size = UDim2.new(0, 14 * scale, 0, 14 * scale),
        Position = UDim2.new(pct, -7 * scale, 0.5, -7 * scale),
        BackgroundColor3 = Config.Accent,
        BorderSizePixel = 0, Text = "", Parent = track
    })
    AddCorner(knob, 7)
    
    sliderValues[key] = default
    local dragging = false
    
    knob.MouseButton1Down:Connect(function() dragging = true end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local p = math.clamp((UIS:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local v = math.floor(minV + p * (maxV - minV))
            fill.Size = UDim2.new(p, 0, 1, 0)
            knob.Position = UDim2.new(p, -7 * scale, 0.5, -7 * scale)
            valTxt.Text = tostring(v)
            sliderValues[key] = v
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

