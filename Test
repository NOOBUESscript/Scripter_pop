local function CheckKeyStatus(key)
    key = key:upper()
    for _, k in ipairs(Config.ActiveKeys) do
        if k:upper() == key then return "active" end
    end
    for _, k in ipairs(Config.ExpiredKeys) do
        if k:upper() == key then return "expired" end
    end
    for _, k in ipairs(Config.BannedKeys) do
        if k:upper() == key then return "banned" end
    end
    return "invalid"
end

