-- ==================== TOGGLE BUTTON ====================

local function CreateToggleButton()
    if player.PlayerGui:FindFirstChild("SilentToggleBtn") then
        player.PlayerGui.SilentToggleBtn:Destroy()
    end
    
    local ToggleGui = Make("ScreenGui", {
        Name = "SilentToggleBtn",
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        DisplayOrder = 999,
        Parent = player.PlayerGui
    })
    
    local btnSize = Config.ToggleButtonSize
    local BtnContainer = Make("Frame", {
        Size = UDim2.new(0, btnSize + 20, 0, btnSize + 20),
        Position = UDim2.new(0, 10, 0.5, -(btnSize + 20)/2),
        BackgroundTransparency = 1,
        Parent = ToggleGui
    })
    
    local CircleBg = Make("Frame", {
        Size = UDim2.new(0, btnSize, 0, btnSize),
        Position = UDim2.new(0.5, -btnSize/2, 0.5, -btnSize/2),
        BackgroundColor3 = Color3.fromRGB(15, 15, 25),
        BorderSizePixel = 2,
        BorderColor3 = Config.Accent,
        Parent = BtnContainer
    })
    AddCorner(CircleBg, btnSize / 2)
    
    local Button = Make("ImageButton", {
        Name = "ToggleBtn",
        Size = UDim2.new(0, btnSize - 8, 0, btnSize - 8),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundTransparency = 1,
        Image = Config.ToggleImageOn,
        ScaleType = Enum.ScaleType.Fit,
        Parent = CircleBg
    })
    AddCorner(Button, (btnSize - 8) / 2)
    
    local dragging = false
    local dragStart, startPos
    local dragDistance = 0
    
    Button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = BtnContainer.Position
            dragDistance = 0
        end
    end)
    
    Button.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            dragDistance = math.sqrt(delta.X^2 + delta.Y^2)
            if dragDistance > 5 then
                BtnContainer.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end
    end)
    
    Button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local wasDragging = dragDistance > 10
            dragging = false
            dragDistance = 0
            if not wasDragging then
                isGUIVisible = not isGUIVisible
                Button.Image = isGUIVisible and Config.ToggleImageOn or Config.ToggleImageOff
                if MainGUIMainFrame and MainGUIMainFrame.Parent then
                    MainGUIMainFrame.Visible = isGUIVisible
                end
            end
        end
    end)
    
    Button.MouseButton2Click:Connect(function()
        if MainGUIMainFrame and MainGUIMainFrame.Parent then
            MainGUIMainFrame.Parent:Destroy()
        end
        ToggleGui:Destroy()
    end)
end

