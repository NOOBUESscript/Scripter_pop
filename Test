-- ==================== UTILITIES ====================
local function Make(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do inst[k] = v end
    return inst
end

local function AddCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function AddPadding(parent, t, b, l, r)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, t or 0)
    p.PaddingBottom = UDim.new(0, b or 0)
    p.PaddingLeft = UDim.new(0, l or 0)
    p.PaddingRight = UDim.new(0, r or 0)
    p.Parent = parent
    return p
end

local function Tween(obj, props, duration)
    local info = TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function CopyToClipboard(text)
    pcall(function()
        if setclipboard then setclipboard(text)
        elseif toclipboard then toclipboard(text) end
    end)
end

local function Shake(gui)
    for i = 1, 4 do
        Tween(gui, {Position = UDim2.new(gui.Position.X.Scale, gui.Position.X.Offset + 6, gui.Position.Y.Scale, gui.Position.Y.Offset)}, 0.04)
        wait(0.04)
        Tween(gui, {Position = UDim2.new(gui.Position.X.Scale, gui.Position.X.Offset - 6, gui.Position.Y.Scale, gui.Position.Y.Offset)}, 0.04)
        wait(0.04)
    end
end

local function LoadImage(parent, imageId, size, fallback)
    local loaded = false
    if imageId and imageId ~= "" then
        local success = pcall(function()
            Make("ImageLabel", {
                Size = size,
                BackgroundTransparency = 1,
                Image = imageId,
                ScaleType = Enum.ScaleType.Fit,
                Parent = parent
            })
            loaded = true
        end)
    end
    if not loaded then
        Make("TextLabel", {
            Size = size,
            BackgroundTransparency = 1,
            Text = fallback or "?",
            TextColor3 = Config.Text,
            TextSize = 16,
            Font = Enum.Font.GothamBold,
            Parent = parent
        })
    end
end

local function Fire(remote, ...)
    pcall(function() remote:FireServer(...) end)
end

